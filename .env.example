# ── Server-side secrets ─────────────────────────────────────────────
# All keys in this file are read ONLY by server code (API routes / lib).
# Never expose these via NEXT_PUBLIC_* — the frontend must not hold
# platform credentials or API keys.

# Anthropic API key for the AI Tutor + long-form grading.
# When unset, the app falls back to a deterministic offline tutor.
ANTHROPIC_API_KEY=

# External platform integrations (used by the server-side adapters).
COURSERA_API_TOKEN=
UDACITY_API_TOKEN=
